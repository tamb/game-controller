{
  "name": "@tamb/gamecontroller",
  "version": "1.0.0-alpha.2",
  "type": "module",
  "description": "A simple HTML skin for a Gameboy-style virtual controller",
  "scripts": {
    "dev": "concurrently \"vite dev\" \"storybook dev -p 6006\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "build": "vite build --config vite.lib.config.ts",
    "start": "npm run storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "beta:publish": "npm run build && npm publish --tag beta --access=public",
    "alpha:publish": "npm run build && npm publish --tag alpha --access=public",
    "safe:publish": "npm run build && npm publish --access=public"
  },
  "keywords": [],
  "author": {
    "name": "Tamb",
    "email": "t.saporito@gmail.com",
    "url": "https://tamb.github.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tamb/game-controller.git"
  },
  "main": "./dist/main.js",
  "module": "./dist/main.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "peerDependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/web-components-vite": "10.3.6",
    "concurrently": "^9.2.1",
    "happy-dom": "^20.9.0",
    "lit": "^3.3.2",
    "storybook": "10.3.6",
    "typescript": "~5.6.3",
    "vite": "^8.0.11",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
